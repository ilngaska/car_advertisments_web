.flex.justify-between.items-center.mb-8
  %h1.text-3xl.font-bold.text-gray-900= t('admin.title')
  = link_to t('admin.add_new'), new_admin_car_advertisement_path, class: "bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 transition"
.bg-white.border.border-gray-200.rounded-xl.shadow-sm.overflow-hidden.text-black
  %table.w-full.text-left
    %thead.bg-gray-50.border-b.border-gray-200.font-semibold.text-gray-700
      %tr
        %th.px-6.py-4.text-sm.uppercase= t('admin.table.car')
        %th.px-6.py-4.text-sm.uppercase= t('admin.table.price')
        %th.px-6.py-4.text-sm.uppercase= t('admin.table.odometer')
        %th.px-6.py-4.text-sm.uppercase= t('admin.table.date_added')
        %th.px-6.py-4.text-right.text-sm.uppercase= t('admin.table.actions')
    %tbody.divide-y.divide-gray-100
      - @cars.each do |car|
        %tr.hover:bg-gray-50.transition
          %td.px-6.py-4
            %span.font-bold.text-gray-900
              = car.make
              = car.model
            %span.text-xs.text-gray-400.ml-2= car.year
          %td.px-6.py-4.font-mono.text-green-600.font-semibold
            $#{number_with_delimiter(car.price)}
          %td.px-6.py-4.text-gray-600
            = number_with_delimiter(car.odometer)
            km
          %td.px-6.py-4.text-gray-500.text-sm
            = car.created_at.present? ? car.created_at.strftime("%Y-%m-%d") : Time.current.strftime("%Y-%m-%d")
          %td.px-6.py-4.text-right
            .flex.justify-end.items-center.space-x-4
              = link_to t('admin.edit'), edit_admin_car_advertisement_path(car), class: "text-blue-600 hover:underline font-medium"
              = button_to t('admin.delete'), admin_car_advertisement_path(car),                                    |
                method: :delete,                                                                                   |
                form: { data: { turbo_confirm: t('admin.confirm'), turbo: false } },                               |
                class: "text-red-600 hover:text-red-800 font-medium bg-transparent border-none cursor-pointer p-0" |
