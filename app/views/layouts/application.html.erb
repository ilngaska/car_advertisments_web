<!DOCTYPE html>
<html>
  <head>
    <title>Car Advertisements Web</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <script src="https://cdn.tailwindcss.com"></script>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-gray-50 text-gray-900 font-sans antialiased">
    <nav class="bg-white border-b border-gray-200 py-4 shadow-sm mb-8">
      <div class="max-w-6xl mx-auto px-4 flex justify-between items-center">
        <%= link_to "Car Advertisements Web", root_path, class: "text-xl font-bold text-gray-800" %>
        <div class="flex items-center space-x-6">
          <%= link_to "Home", root_path, class: "text-sm font-bold #{current_page?(root_path) ? 'text-blue-600' : 'text-gray-500'}" %>
          <%= link_to "Cars", cars_path, class: "text-sm font-bold #{current_page?(cars_path) ? 'text-blue-600' : 'text-gray-500'}" %>
          <%= link_to "Search", searches_path, class: "text-sm font-bold #{current_page?(searches_path) ? 'text-blue-600' : 'text-gray-500'}" %>
          <%= link_to "Help", help_index_path, class: "text-sm font-bold #{current_page?(help_index_path) ? 'text-blue-600' : 'text-gray-500'}" %>
        </div>
      </div>
    </nav>
    <main class="max-w-6xl mx-auto px-4"><%= yield %></main>
  </body>
</html>