.max-w-4xl.mx-auto.py-12.px-4
  %h1.text-4xl.font-bold.text-gray-900.mb-2= t('searches.index.title', default: 'Search Cars')
  
  = form_with url: cars_path, method: :get, scope: :car, local: true, class: "space-y-6 bg-white p-8 border border-gray-200 rounded-xl shadow-sm" do |f|
    .grid.grid-cols-1.md:grid-cols-2.gap-6
      %div
        = f.label :make, t('cars.fields.make', default: 'Make'), class: "block text-sm font-bold text-gray-700 mb-2"
        = f.text_field :make, value: params.dig(:car, :make), placeholder: "e.g., Toyota", class: "w-full p-3 border border-gray-300 rounded-md outline-none focus:ring-2 focus:ring-blue-500"
      %div
        = f.label :model, t('cars.fields.model', default: 'Model'), class: "block text-sm font-bold text-gray-700 mb-2"
        = f.text_field :model, value: params.dig(:car, :model), placeholder: "e.g., Camry", class: "w-full p-3 border border-gray-300 rounded-md outline-none focus:ring-2 focus:ring-blue-500"
    
    .grid.grid-cols-1.md:grid-cols-2.gap-6
      %div
        = f.label :year_from, t('cars.fields.year_from', default: 'Year From'), class: "block text-sm font-bold text-gray-700 mb-2"
        = f.number_field :year_from, value: params.dig(:car, :year_from), class: "w-full p-3 border border-gray-300 rounded-md outline-none focus:ring-2 focus:ring-blue-500"
      %div
        = f.label :year_to, t('cars.fields.year_to', default: 'Year To'), class: "block text-sm font-bold text-gray-700 mb-2"
        = f.number_field :year_to, value: params.dig(:car, :year_to), class: "w-full p-3 border border-gray-300 rounded-md outline-none focus:ring-2 focus:ring-blue-500"
    
    .grid.grid-cols-1.md:grid-cols-2.gap-6.pb-6.border-b.border-gray-100
      %div
        = f.label :price_from, t('cars.fields.price_from', default: 'Min Price ($)'), class: "block text-sm font-bold text-gray-700 mb-2"
        = f.number_field :price_from, value: params.dig(:car, :price_from), class: "w-full p-3 border border-gray-300 rounded-md outline-none focus:ring-2 focus:ring-blue-500"
      %div
        = f.label :price_to, t('cars.fields.price_to', default: 'Max Price ($)'), class: "block text-sm font-bold text-gray-700 mb-2"
        = f.number_field :price_to, value: params.dig(:car, :price_to), class: "w-full p-3 border border-gray-300 rounded-md outline-none focus:ring-2 focus:ring-blue-500"
    
    .flex.items-center.space-x-4.pt-6
      = f.submit t('buttons.search', default: 'Search'), class: "bg-blue-600 text-white px-8 py-3 rounded-md font-bold hover:bg-blue-700 cursor-pointer shadow-sm transition"
      = link_to t('buttons.reset', default: 'Reset'), searches_path, class: "bg-gray-100 text-gray-700 px-8 py-3 rounded-md font-bold hover:bg-gray-200 transition"
      
  = link_to t('help.index.back'), root_path, class: "inline-block mt-8 text-blue-600 font-bold hover:underline"