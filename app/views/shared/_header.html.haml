%nav.bg-white.border-b.border-gray-200.py-4.shadow-sm.mb-8
  .max-w-6xl.mx-auto.px-4.flex.justify-between.items-center
    = link_to "Car Advertisements Web", root_path, class: "text-xl font-bold text-gray-800"
    
    .flex.items-center.space-x-6
      = link_to t('nav.home'), root_path, class: "text-sm font-bold #{current_page?(root_path) ? 'text-blue-600' : 'text-gray-500'}"
      = link_to t('nav.cars'), cars_path, class: "text-sm font-bold #{current_page?(cars_path) ? 'text-blue-600' : 'text-gray-500'}"
      = link_to t('nav.search'), searches_path, class: "text-sm font-bold #{current_page?(searches_path) ? 'text-blue-600' : 'text-gray-500'}"
      
      - if session[:user_email]
        = link_to t('nav.history'), search_histories_path, class: "text-sm font-bold #{current_page?(search_histories_path) ? 'text-blue-600' : 'text-gray-500 hover:text-blue-600'}"
      
      = link_to t('nav.help'), help_index_path, class: "text-sm font-bold #{current_page?(help_index_path) ? 'text-blue-600' : 'text-gray-500'}"

      .flex.items-center.space-x-3.ml-4
        - if session[:user_email]
          %span.text-sm.text-gray-600= t('nav.greeting', email: session[:user_email])
          = link_to t('nav.logout'), logout_path, class: "text-red-600 text-sm font-bold hover:underline"
        - else
          = link_to t('nav.login'), new_session_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 px-3 py-2"
          = link_to t('nav.signup'), new_user_path, class: "text-sm font-medium bg-blue-600 text-white px-4 py-2 rounded-md hover:bg-blue-700 transition shadow-sm"