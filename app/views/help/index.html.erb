<div class="max-w-3xl mx-auto py-12 px-4">
  <h1 class="text-4xl font-bold mb-8 text-gray-900"><%= t('help.title') %></h1>

  <div class="space-y-10">
    <section>
      <h2 class="text-xl font-bold mb-4 border-b pb-2"><%= t('help.getting_started.title') %></h2>
      <div class="space-y-4 text-gray-700">
        <p><%= t('help.getting_started.browse') %></p>
        <p><%= t('help.getting_started.search') %></p>
      </div>
    </section>

    <section>
      <h2 class="text-xl font-bold mb-4 border-b pb-2"><%= t('help.faq.title') %></h2>
      <div class="space-y-6">
        <div>
          <h4 class="font-bold text-gray-800"><%= t('help.faq.question') %></h4>
          <p class="text-sm text-gray-600 italic"><%= t('help.faq.answer') %></p>
        </div>
      </div>
    </section>

    <%= link_to t('common.back_home'), root_path, class: "inline-block text-blue-600 font-bold hover:underline" %>
  </div>
</div>
