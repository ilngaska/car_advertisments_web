<div class="max-w-4xl mx-auto px-4 py-12">
  <div class="mb-10 text-center">
    <h1 class="text-4xl font-extrabold text-gray-900 mb-2"><%= t('history.title') %></h1>
    <p class="text-gray-500 text-lg"><%= t('history.subtitle') %></p>
  </div>

  <% if @current_user.history.any? %>
    <div class="space-y-6">
      <% @current_user.history.reverse.each do |entry| %>
        <div class="bg-white border border-gray-100 rounded-3xl p-6 shadow-sm">
          <div class="flex justify-between items-start mb-4">
            <div class="flex items-center gap-2">
              <span class="font-bold text-gray-800">
                <%= t('history.query_date', date: (entry['timestamp'] || entry[:timestamp])) %>
              </span>
            </div>
          </div>

          <div class="flex flex-wrap gap-2">
            <% query_data = entry['query'] || entry[:query] %>
            <% if query_data.is_a?(Hash) %>
              <% query_data.each do |key, value| %>
                <% if value.present? %>
                  <div class="flex items-center bg-gray-50 border border-gray-200 px-3 py-1.5 rounded-xl">
                    <span class="text-xs font-semibold text-gray-400 uppercase mr-2">
                      <%= t("history.fields.#{key}", default: key.to_s.humanize) %>:
                    </span>
                    <span class="text-sm font-bold text-gray-700"><%= value %></span>
                  </div>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <h3 class="text-xl font-bold text-gray-900"><%= t('history.empty') %></h3>
    </div>
  <% end %>
</div>