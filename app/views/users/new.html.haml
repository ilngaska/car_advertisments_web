.max-w-md.mx-auto.bg-white.p-8.border.border-gray-200.rounded-lg.shadow-sm
  %h1.text-2xl.font-bold.text-center.mb-6= t('nav.signup')

  = form_with model: @user, url: users_path, local: true do |f|
    .mb-4
      = f.label :email, class: "block text-sm font-medium text-gray-700 mb-1"
      = f.email_field :email, class: "w-full p-2 border border-gray-300 rounded-md shadow-sm"

    .mb-4
      = f.label :password, class: "block text-sm font-medium text-gray-700 mb-1"
      = f.password_field :password, class: "w-full p-2 border border-gray-300 rounded-md shadow-sm"

    .mb-6
      = f.label :password_confirmation, class: "block text-sm font-medium text-gray-700 mb-1"
      = f.password_field :password_confirmation, class: "w-full p-2 border border-gray-300 rounded-md shadow-sm"

    = f.submit t('nav.signup'), class: "w-full bg-green-600 text-white font-bold py-2 rounded-md hover:bg-green-700 transition cursor-pointer"

  .mt-6.text-center.text-sm.text-gray-500
    = t('login.already_account')
    \#{link_to t('nav.login'), new_session_path, class: "text-blue-600 font-bold hover:underline"}
    