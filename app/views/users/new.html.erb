<div class="max-w-md mx-auto mt-10 p-6 bg-white rounded-lg shadow-md">
  <h2 class="text-2xl font-bold mb-6">Реєстрація</h2>

  <%= form_with model: @user, url: signup_path do |f| %>
    <% if @user.errors.any? %>
      <div class="text-red-500 mb-4">
        <% @user.errors.full_messages.each do |message| %>
          <p><%= message %></p>
        <% end %>
      </div>
    <% end %>

    <div class="mb-4">
      <%= f.label :email, class: "block text-sm font-medium" %>
      <%= f.email_field :email, class: "w-full border rounded p-2" %>
    </div>

    <div class="mb-4">
      <%= f.label :password, t('login.password'), class: "block text-sm font-medium" %>
      <%= f.password_field :password, class: "w-full border rounded p-2" %>
    </div>

    <div class="mb-6">
      <%= f.label :password_confirmation, t('login.confirm'), class: "block text-sm font-medium" %>
      <%= f.password_field :password_confirmation, class: "w-full border rounded p-2" %>
    </div>

    <%= f.submit t('login.signup'), class: "w-full bg-blue-600 text-white py-2 rounded hover:bg-blue-700 cursor-pointer" %>
  <% end %>
</div>