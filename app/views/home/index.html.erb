<div class="py-12 px-4 max-w-6xl mx-auto">
  <h1 class="text-4xl font-extrabold mb-4 text-gray-900"><%= t('general.welcome') %></h1>
  <p class="text-gray-600 mb-10 max-w-2xl text-lg">
    <%= t('general.welc_message') %>
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%= link_to cars_path, class: "p-8 border-2 rounded-xl bg-blue-50 border-blue-200 hover:border-blue-400 transition group shadow-sm" do %>
      <h3 class="text-xl font-bold mb-2 group-hover:text-blue-700 text-gray-900"><%= t('general.browse') %></h3>
      <p class="text-sm text-gray-500"><%= t('general.browse_message') %></p>
    <% end %>
    <%= link_to search_cars_path, class: "p-8 border rounded-xl border-gray-200 hover:shadow-md transition text-gray-900 bg-white shadow-sm" do %>
      <h3 class="text-xl font-bold mb-2"><%= t('nav.search') %></h3>
      <p class="text-sm text-gray-500"><%= t('general.search_message') %></p>
    <% end %>
    <% if logged_in? %>
      <div class="p-8 border rounded-xl border-gray-100 text-gray-400 bg-gray-50 shadow-sm italic">
        <h3 class="text-xl font-bold mb-2"><%= t('nav.greeting', email: current_user.email.split('@').first) %></h3>
        <p class="text-sm"><%= t('general.already_member') %></p>
      </div>
    <% else %>
      <%= link_to signup_path, class: "p-8 border rounded-xl border-gray-200 hover:shadow-md transition text-gray-900 bg-white shadow-sm" do %>
        <h3 class="text-xl font-bold mb-2"><%= t('nav.signup') %></h3>
        <p class="text-sm text-gray-500"><%= t('general.signup_message') %></p>
      <% end %>
    <% end %>
    <%= link_to help_path, class: "p-8 border rounded-xl border-gray-200 hover:shadow-md transition text-gray-900 bg-white shadow-sm" do %>
      <h3 class="text-xl font-bold mb-2"><%= t('nav.help') %></h3>
      <p class="text-sm text-gray-500"><%= t('general.help_message') %></p>
    <% end %>
  </div>
  <div class="mt-12 p-8 bg-gray-50 border border-gray-200 rounded-xl">
    <h3 class="text-lg font-bold text-gray-900 mb-2"><%= t('general.about') %></h3>
    <p class="text-sm text-gray-600 italic"><%= t('general.about_message') %></p>
  </div>
</div>
