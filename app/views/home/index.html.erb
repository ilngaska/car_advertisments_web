<div class="py-12 px-4 max-w-6xl mx-auto">
  <h1 class="text-4xl font-extrabold mb-4 text-gray-900"><%= t('general.welcome') %></h1>
  <p class="text-gray-600 mb-10 max-w-2xl text-lg">
    <%= t('general.welc_message') %>
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%= link_to cars_path, class: "p-8 border-2 rounded-xl bg-blue-50 border-blue-200 hover:border-blue-400 transition group shadow-sm" do %>
      <h3 class="text-xl font-bold mb-2 group-hover:text-blue-700 text-gray-900"><%= t('general.browse') %></h3>
      <p class="text-sm text-gray-500"><%= t('general.browse_message') %></p>
    <% end %>

    <%= link_to searches_path, class: "p-8 border rounded-xl border-gray-200 hover:shadow-md transition text-gray-900 bg-white shadow-sm" do %>
      <h3 class="text-xl font-bold mb-2"><%= t('general.search') %></h3>
      <p class="text-sm text-gray-500"><%= t('general.search_message') %></p>
    <% end %>

    <div class="p-8 border rounded-xl border-gray-200 text-gray-900 bg-white opacity-60 shadow-sm">
      <h3 class="text-xl font-bold mb-2"><%= t('general.signup') %></h3>
      <p class="text-sm text-gray-500"><%= t('general.signup_message') %></p>
    </div>

    <%= link_to help_index_path, class: "p-8 border rounded-xl border-gray-200 hover:shadow-md transition text-gray-900 bg-white shadow-sm" do %>
      <h3 class="text-xl font-bold mb-2"><%= t('general.help') %></h3>
      <p class="text-sm text-gray-500"><%= t('general.help_message') %></p>
    <% end %>
  </div>
</div>
