<div class="py-12 px-4 max-w-6xl mx-auto">
  <h1 class="text-4xl font-extrabold mb-4 text-gray-900">Welcome to Car Advertisements Web</h1>
  <p class="text-gray-600 mb-10 max-w-2xl text-lg">
    Browse, search, and manage car advertisements. This is a simple learning project demonstrating basic CRUD operations and authentication patterns.
  </p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%= link_to cars_path, class: "p-8 border-2 rounded-xl bg-blue-50 border-blue-200 hover:border-blue-400 transition group shadow-sm" do %>
      <h3 class="text-xl font-bold mb-2 group-hover:text-blue-700 text-gray-900">Browse Cars</h3>
      <p class="text-sm text-gray-500">View all car advertisements with sorting and pagination</p>
    <% end %>

    <%= link_to search_cars_path, class: "p-8 border rounded-xl border-gray-200 hover:shadow-md transition text-gray-900 bg-white shadow-sm" do %>
      <h3 class="text-xl font-bold mb-2">Search</h3>
      <p class="text-sm text-gray-500">Find specific cars using advanced search filters</p>
    <% end %>

    <div class="p-8 border rounded-xl border-gray-200 text-gray-900 bg-white opacity-60 shadow-sm">
      <h3 class="text-xl font-bold mb-2">Create Account</h3>
      <p class="text-sm text-gray-500">Sign up to save searches and manage your preferences</p>
    </div>

    <%= link_to help_path, class: "p-8 border rounded-xl border-gray-200 hover:shadow-md transition text-gray-900 bg-white shadow-sm" do %>
      <h3 class="text-xl font-bold mb-2">Help</h3>
      <p class="text-sm text-gray-500">Learn how to use the platform and find answers to common questions</p>
    <% end %>
  </div>

  <div class="mt-12 p-8 bg-gray-50 border border-gray-200 rounded-xl">
    <h3 class="text-lg font-bold text-gray-900 mb-2">About This Project</h3>
    <p class="text-sm text-gray-600 italic">This is a reference implementation for learning Ruby on Rails with a Tailwind CSS frontend. The UI is intentionally minimal to focus on functionality.</p>
  </div>
</div>
