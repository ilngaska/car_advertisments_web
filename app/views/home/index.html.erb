<div class="max-w-5xl mx-auto px-4 py-12">
  <div class="mb-12">
    <h1 class="text-4xl font-bold text-gray-900 mb-4">Welcome to Car Advertisements Web</h1>
    <p class="text-gray-600 text-lg">
      Browse, search, and manage car advertisements. This is a simple learning project demonstrating basic CRUD operations and authentication patterns.
    </p>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <%= link_to cars_path, class: "group p-8 bg-white border border-gray-200 rounded-lg hover:border-blue-500 hover:bg-blue-50 transition shadow-sm" do %>
      <h2 class="text-xl font-bold text-gray-900 group-hover:text-blue-700 mb-2">Browse Cars</h2>
      <p class="text-gray-500">View all car advertisements with sorting and pagination</p>
    <% end %>

    <%= link_to search_cars_path, class: "group p-8 bg-white border border-gray-200 rounded-lg hover:border-blue-500 hover:bg-blue-50 transition shadow-sm" do %>
      <h2 class="text-xl font-bold text-gray-900 group-hover:text-blue-700 mb-2">Search</h2>
      <p class="text-gray-500">Find specific cars using advanced search filters</p>
    <% end %>

    <div class="group p-8 bg-white border border-gray-200 rounded-lg opacity-60">
      <h2 class="text-xl font-bold text-gray-900 mb-2">Create Account</h2>
      <p class="text-gray-500">Sign up to save searches and manage your preferences</p>
    </div>

    <%= link_to "#", class: "group p-8 bg-white border border-gray-200 rounded-lg hover:border-blue-500 hover:bg-blue-50 transition shadow-sm" do %>
      <h2 class="text-xl font-bold text-gray-900 group-hover:text-blue-700 mb-2">Help</h2>
      <p class="text-gray-500">Learn how to use the platform and find answers to common questions</p>
    <% end %>
  </div>

  <div class="mt-12 p-8 bg-gray-50 border border-gray-200 rounded-lg text-sm text-gray-600">
    <h3 class="font-bold mb-2 uppercase tracking-wider text-gray-400">About This Project</h3>
    <p>This is a reference implementation for learning Ruby on Rails with a Tailwind CSS frontend. The UI is intentionally minimal to focus on functionality and best practices.</p>
  </div>
</div>