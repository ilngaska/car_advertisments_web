<div class="max-w-md mx-auto mt-12 p-8 bg-white border border-gray-200 rounded-xl shadow-lg">
  <h2 class="text-2xl font-bold mb-6 text-center text-gray-900"><%= t('login.title') %></h2>

  <%= form_with url: login_path, local: true do |f| %>
    <div class="mb-4">
      <%= f.label :email, t('login.email'), class: "block text-sm font-bold text-gray-700 mb-1" %>
      <%= f.email_field :email, class: "w-full p-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <div class="mb-6">
      <%= f.label :password, t('login.password'), class: "block text-sm font-bold text-gray-700 mb-1" %>
      <%= f.password_field :password, class: "w-full p-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500" %>
    </div>

    <%= f.submit t('login.submit'), class: "w-full bg-blue-600 text-white font-bold py-2 rounded-md hover:bg-blue-700 transition cursor-pointer" %>
  <% end %>
</div>