<div class="max-w-4xl mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Search Cars</h1>
  <p class="text-gray-500 mb-8">Use the filters below to find cars that match your criteria</p>

  <%= form_with url: search_cars_path, method: :get, local: true, class: "space-y-6 bg-white p-8 border border-gray-200 rounded-lg shadow-sm" do |f| %>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <%# Марка та Модель %>
      <div class="space-y-2">
        <label class="text-sm font-bold text-gray-700">Make</label>
        <%= f.text_field :make, value: params[:make], placeholder: "e.g. BMW", class: "w-full border-gray-300 rounded-md shadow-sm p-2" %>
      </div>
      <div class="space-y-2">
        <label class="text-sm font-bold text-gray-700">Model</label>
        <%= f.text_field :model, value: params[:model], placeholder: "e.g., Camry", class: "w-full border-gray-300 rounded-md shadow-sm p-2" %>
      </div>

  <div class="flex space-x-2">
  <div class="w-1/2">
    <label class="block text-xs font-black uppercase text-gray-400 mb-1 ml-1">Рік від</label>
    <%= f.select :year_from, 
        options_for_select(1920..Time.now.year, params[:year_from] || 1920), 
        { include_blank: "Від" }, 
        class: "w-full border-gray-300 rounded-md shadow-sm p-2 bg-white" %>
  </div>

  <div class="w-1/2">
    <label class="block text-xs font-black uppercase text-gray-400 mb-1 ml-1">Рік до</label>
    <%= f.select :year_to, 
        options_for_select((1920..Time.now.year).to_a.reverse, params[:year_to] || Time.now.year), 
        { include_blank: "До" }, 
        class: "w-full border-gray-300 rounded-md shadow-sm p-2 bg-white" %>
  </div>
  </div>

      <%# Ціна %>
      <div class="space-y-2">
        <label class="text-sm font-bold text-gray-700">Price Range ($)</label>
        <div class="flex gap-2">
          <%= f.number_field :price_from, value: params[:price_from], placeholder: "Min price", class: "w-1/2 border-gray-300 rounded-md shadow-sm p-2" %>
          <%= f.number_field :price_to, value: params[:price_to], placeholder: "Max price", class: "w-1/2 border-gray-300 rounded-md shadow-sm p-2" %>
        </div>
      </div>
    </div>

    <div class="flex justify-between items-center pt-6 border-t border-gray-100">
      <div class="flex gap-3">
        <%= f.submit "Search", class: "bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded-md shadow transition" %>
        <%= link_to "Reset", search_cars_path, class: "bg-gray-100 hover:bg-gray-200 text-gray-700 font-bold py-2 px-6 rounded-md transition" %>
      </div>
      <button type="button" class="text-gray-500 border border-gray-300 py-2 px-6 rounded-md hover:bg-gray-50 font-medium">Save Search</button>
    </div>
  <% end %>

  <div class="mt-6 p-4 bg-blue-50 border border-blue-100 rounded-md text-sm text-blue-700">
    <strong>Note:</strong> You must be logged in to save search criteria. Saved searches can be accessed from the "My Searches" page.
  </div>

  <%# Вивід результатів, якщо вони є %>
  <% if @results&.any? %>
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
      <% @results.each do |car| %>
        <div class="p-5 border rounded-xl bg-white shadow-sm">
          <h3 class="font-bold text-lg"><%= "#{car['make']} #{car['model']}" %></h3>
          <p class="text-green-700 font-bold text-xl">$<%= car['price'] %></p>
          <p class="text-sm text-gray-400 mt-2">Year: <%= car['year'] %> | Mileage: <%= car['odometer'] %> mi</p>
        </div>
      <% end %>
    </div>
    <div class="mt-8 flex justify-center">
      <%== pagy_nav(@pagy) %>
    </div>
  <% end %>
</div>